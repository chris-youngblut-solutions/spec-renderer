# --- Universal floor: applies to every repo ---

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# OS / shell crud
.fseventsd/
.Spotlight-V100/
.Trashes/
ehthumbs.db
$RECYCLE.BIN/

# Direnv / env
.envrc.local
.env
.env.local
.env.*.local

# Claude Code per-user
.claude/settings.local.json
.claude/sessions/
.claude/cache/
.claude/file-history/
CLAUDE.local.md

# Logs / coverage / temp
*.log
*.log.*
logs/
coverage/
.coverage
.coverage.*
htmlcov/
.tmp/
tmp/
.cache/

# Build outputs (per-language overlays add specifics)
dist/
build/
out/

# Secrets shapes (defense in depth — gitleaks is the real backstop)
*.pem
*.key
!**/test-fixtures/**/*.pem
!**/test-fixtures/**/*.key
*.p12
*.pfx
*.kdbx
secrets/
.secrets/
